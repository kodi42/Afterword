{
  "expo": {
    "name": "Afterword",
    "slug": "afterword",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "afterword",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kodi.afterword"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
